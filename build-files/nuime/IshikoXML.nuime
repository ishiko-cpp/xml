<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="https://nuime.org/schema/core/1">
  <name>IshikoXML</name>
  <targets>
    <target>
      <name>lib</name>
      <labels>
        <label>nuime:product</label>
      </labels>
      <build-dependencies>
        <dependency>
          <name>IshikoFileSystem</name>
          <target-refs>
            <target-ref>
              <location>
                <url>https://github.com/ishiko-cpp/filesystem/build-files/nuime/IshikoFileSystem.nuime</url>
              </location>
              <name>lib</name>
            </target-ref>
          </target-refs>
        </dependency>
        <dependency>
          <name>IshikoErrors</name>
          <target-refs>
            <target-ref>
              <location>
                <url>https://github.com/ishiko-cpp/errors/build-files/nuime/IshikoErrors.nuime</url>
              </location>
              <name>lib</name>
            </target-ref>
          </target-refs>
        </dependency>
      </build-dependencies>
      <properties>
        <property name="nuime:test-suite">
          <target-ref>
            <location>
              <url>https://github.com/ishiko-cpp/xml/tests/build-files/nuime/IshikoXMLTests.nuime</url>
            </location>
            <name>tests</name>
          </target-ref>
        </property>
      </properties>
    </target>
  </targets>
  <subprojects>
    <subproject>
      <name>IshikoXMLTests</name>
      <labels>
        <label>nuime:tests</label>
      </labels>
      <location>
        <url>https://github.com/ishiko-cpp/xml/tests/build-files/nuime/IshikoXMLTests.nuime</url>
      </location>
    </subproject>
  </subprojects>
</project>
